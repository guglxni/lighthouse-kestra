# Lighthouse — copy to `.env` at repo root. Used by docker compose (NOT committed).

# --- Postgres (single instance: lh app + Kestra + Miniflux DB) ---
POSTGRES_USER=lighthouse
POSTGRES_PASSWORD=lighthouse_change_me
POSTGRES_DB=lighthouse

# --- LiteLLM BYOK (canonical LLM path for Kestra flows) ---
# Users must supply at least one upstream provider key for LiteLLM (below: OPENAI_API_KEY).
LITELLM_API_KEY=sk-lighthouse-master-change-me
LITELLM_BASE_URL=http://litellm:4000/v1
LITELLM_MODEL_PRIMARY=gpt-5.4
LITELLM_MODEL_FALLBACK=gpt-5.5
# single = one model id from Kestra; multi = use LiteLLM router/fallback config + optional runIf chains
LITELLM_MODE=single
OPENAI_API_KEY=

# Optional additional providers (for LiteLLM multi-model / Azure Kimi placeholders)
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=

# --- Optional enrichment ---
EXA_API_KEY=

# --- Delivery ---
NOTION_API_KEY=
SLACK_BOT_TOKEN=
SLACK_WEBHOOK_URL=
SENDGRID_API_KEY=
DISCORD_WEBHOOK_AGENTIC=
DISCORD_WEBHOOK_SOLANA=
DISCORD_WEBHOOK_INDIE=
DISCORD_WEBHOOK_DATAENG=

NOTION_PAGE_AGENTIC=
NOTION_PAGE_SOLANA=
NOTION_PAGE_INDIE=
NOTION_PAGE_DATAENG=

# --- Sources ---
MINIFLUX_TOKEN=
MINIFLUX_ADMIN_USER=admin
MINIFLUX_ADMIN_PASSWORD=changeme1234
MINIFLUX_WEBHOOK_SECRET=changeme
GITHUB_TOKEN=
REDDIT_USER_AGENT=lighthouse-research/0.1

# --- Archive (future gc/S3 integrations) ---
S3_BUCKET=
S3_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
