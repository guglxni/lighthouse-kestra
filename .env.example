# Lighthouse — copy to `.env` at repo root. Used by docker compose (NOT committed).

# --- Postgres (single instance: lh app + Kestra + Miniflux DB) ---
POSTGRES_USER=lighthouse
POSTGRES_PASSWORD=lighthouse_change_me
POSTGRES_DB=lighthouse

# --- LiteLLM BYOK (canonical LLM path for Kestra flows) ---
# Provider-agnostic: Kestra calls OpenAI-shaped HTTP only. You map models in infra/litellm/config.yaml.
# LITELLM_MODEL_* must match model_name entries in that file (any names you choose).
LITELLM_API_KEY=sk-lighthouse-master-change-me
LITELLM_BASE_URL=http://litellm:4000/v1
LITELLM_MODEL_PRIMARY=gpt-5.4
LITELLM_MODEL_FALLBACK=gpt-5.5
# single = one model id from Kestra; multi = use LiteLLM router/fallback config + optional runIf chains
LITELLM_MODE=single

# Provider keys — set whichever rows you enabled in infra/litellm/config.yaml (not all required).
OPENAI_API_KEY=
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
GROQ_API_KEY=
# Custom OpenAI-compatible gateway (LiteLLM model_list api_base / api_key)
CUSTOM_LLM_BASE_URL=
CUSTOM_LLM_API_KEY=
OLLAMA_BASE_URL=http://host.docker.internal:11434
OLLAMA_API_KEY=

# --- Optional enrichment (Exa BYOK) ---
# API key from https://exa.ai — no key = flow skips via allowFailure
EXA_API_KEY=
# Base URL only, no path (default public Exa API)
EXA_API_BASE=https://api.exa.ai

# --- Delivery ---
NOTION_API_KEY=
# Optional bot token (not used by alerts flow; reserved for future Slack tasks).
SLACK_BOT_TOKEN=
# Required for monitors/alerts — Slack *Incoming Webhook* URL (https://hooks.slack.com/...).
SLACK_WEBHOOK_URL=
# Public base URL for alert links (no trailing slash), e.g. https://kestra.example.com
KESTRA_PUBLIC_URL=http://localhost:8080
SENDGRID_API_KEY=
DISCORD_WEBHOOK_AGENTIC=
DISCORD_WEBHOOK_SOLANA=
DISCORD_WEBHOOK_INDIE=
DISCORD_WEBHOOK_DATAENG=

NOTION_PAGE_AGENTIC=
NOTION_PAGE_SOLANA=
NOTION_PAGE_INDIE=
NOTION_PAGE_DATAENG=

# --- Sources ---
MINIFLUX_TOKEN=
MINIFLUX_ADMIN_USER=admin
# SECURITY: use strong unique values before exposing Miniflux (e.g. openssl rand -base64 24).
MINIFLUX_ADMIN_PASSWORD=changeme1234
MINIFLUX_WEBHOOK_SECRET=changeme
GITHUB_TOKEN=
REDDIT_USER_AGENT=lighthouse-research/0.1

# --- Archive (future gc/S3 integrations) ---
S3_BUCKET=
S3_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
