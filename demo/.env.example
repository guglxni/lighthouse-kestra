# ─────────────────────────────────────────────────────────────────────
# Supabase (auth + user settings + sample brief history). Required.
# ─────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://qtvlohzprhrworvhlchk.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_4fbhax3nAhD3XrNNOqChQg_nidwEXzF
NEXT_PUBLIC_SITE_URL=http://localhost:3010

# Service role key — never exposed to the browser. Used by /api/notify to
# read all subscriber webhooks (bypasses RLS). Get it from:
# Supabase Dashboard → Project Settings → API → service_role key.
# SUPABASE_SERVICE_ROLE_KEY=eyJ...

# ─────────────────────────────────────────────────────────────────────
# Per-user delivery (/api/notify). Set both in Kestra secrets too.
# ─────────────────────────────────────────────────────────────────────
# Shared secret between Kestra and the demo. Generate with: openssl rand -hex 32
# NOTIFY_SECRET=

# ─────────────────────────────────────────────────────────────────────
# Optional: probes for the live status panel. All are safe to omit.
# ─────────────────────────────────────────────────────────────────────
KESTRA_PUBLIC_URL=http://127.0.0.1:8080
KESTRA_TENANT=main

# Public Kestra → use ONE of these to authenticate probes:
# KESTRA_API_TOKEN=
# KESTRA_BASIC_AUTH_USER=
# KESTRA_BASIC_AUTH_PASSWORD=

# Reads lh.* tables to show real brief / document counts.
# DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@db.qtvlohzprhrworvhlchk.supabase.co:5432/postgres

# Surface gateway models in the "AI router" pill (LiteLLM/OpenAI-compatible).
# LITELLM_BASE_URL=http://127.0.0.1:4000/v1
# LITELLM_API_KEY=
